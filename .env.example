# Copiază acest fișier în `.env` și completează valorile reale.
#   cp .env.example .env
# `.env` este gitignored — NU ajunge pe GitHub. `docker compose up` îl citește automat.

# --- Claude (asistent fiscal /advisor) ---
# de la: https://platform.claude.com  ->  API Keys  ->  Create Key   (începe cu sk-ant-)
ANTHROPIC_API_KEY=

# --- Voyage (embeddings pentru RAG: /advisor + /knowledge) ---
# de la: https://dash.voyageai.com  ->  API Keys
VOYAGE_API_KEY=

# --- Pinecone (baza vectorială pentru legislație) ---
# de la: https://app.pinecone.io  ->  API Keys
PINECONE_API_KEY=
# environment/region al indexului tău (ex: us-east-1-aws, gcp-starter etc.)
PINECONE_ENVIRONMENT=
# numele indexului — TREBUIE creat cu dimension=1024 (Voyage voyage-3.5)
PINECONE_INDEX_NAME=fiscal-assistant-index

# --- JWT (semnarea token-urilor) ---
# minim 32 de caractere. Lasă gol ca să folosești default-ul dev din docker-compose.
JWT_SECRET=
